<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="adw" version="1.0"/>

  <object class="AdwPreferencesPage" id="main_prefs">

    <child>
      <object id="panel_section" class="AdwPreferencesGroup"/>
    </child>

    <child>
      <object id="controls_section" class="AdwPreferencesGroup"/>
    </child>

    <child>
      <object id="shortcuts_section" class="AdwPreferencesGroup"/>
    </child>

    <child>
      <object id="appearance_section" class="AdwPreferencesGroup"/>
    </child>

    <child>
      <object id="behavior_section" class="AdwPreferencesGroup"/>
    </child>

  </object>
</interface>
